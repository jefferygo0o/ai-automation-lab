# ==========================================
# AuraSearch AI - Environment Configuration
# ==========================================
# Copy this file to .env.local and fill in your values.
# All settings are optional — the app defaults to local/free options.

# --- LLM Provider ---
# Default: Ollama (local)
# Set these to use Ollama:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Alternative: OpenAI-compatible API (Groq, Together, etc.)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=mixtral-8x7b-32768

# Alternative: Google Gemini
# GEMINI_API_KEY=your-gemini-key

# --- Search Providers ---
# Default: DuckDuckGo (free, no key needed)
# To use Brave Search API (free tier: 2000 queries/month):
# BRAVE_SEARCH_API_KEY=your-brave-key

# To use Tavily Search (free tier: 1000 queries/month):
# TAVILY_API_KEY=your-tavily-key

# Self-hosted SearXNG:
# SEARXNG_BASE_URL=http://localhost:4000

# --- Other Services ---
# Weather: OpenWeatherMap (free tier)
# OPENWEATHER_API_KEY=your-openweather-key

# --- Feature Flags ---
# ENABLE_VOICE=true
# ENABLE_BROWSER_AUTOMATION=false
# MEMORY_ENABLED=true
